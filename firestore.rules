rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile documents
    // Ensuring a logged-in user can only read and write their own personal profile data (Passport, PAN, Age, Bio)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Booking documents
    // Ensuring a logged-in user can only access their own booking records
    match /bookings/{bookingId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Flights and hotels data
    // Publicly readable, write operations are completely blocked
    match /flights/{flightId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /hotels/{hotelId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
